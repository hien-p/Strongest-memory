{
  "name": "strongest",
  "version": "0.0.1",
  "private": true,
  "description": "OpenClaw × 0G — every agent is a tradeable, encrypted, royalty-bearing iNFT (ERC-7857). Hackathon submission for 0G APAC Hackathon (Track 1).",
  "license": "MIT",
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter \"!@strongest/contracts\" -r test",
    "contracts:build": "pnpm --filter @strongest/contracts build",
    "contracts:test": "pnpm --filter @strongest/contracts test",
    "contracts:deploy:galileo": "pnpm --filter @strongest/contracts deploy:galileo",
    "contracts:deploy:aristotle": "pnpm --filter @strongest/contracts deploy:aristotle",
    "web:dev": "python3 -m http.server 8787 --directory apps/web",
    "web:deploy": "wrangler deploy",
    "landing:dev": "pnpm --filter @strongest/landing dev",
    "landing:build": "pnpm --filter @strongest/landing build",
    "landing:stage": "pnpm landing:build && cp -R apps/landing/dist/. apps/web/",
    "oracle:dev": "cd apps/oracle && cargo run"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0"
  }
}

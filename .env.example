# =====================================================================
# strongest — environment variables
# Copy this file to .env (gitignored) and fill in real values.
# =====================================================================

# ---------- Networks ----------
DEPLOYER_PRIVATE_KEY=0xREPLACE_ME
ARISTOTLE_RPC=https://evmrpc.0g.ai
GALILEO_RPC=https://evmrpc-testnet.0g.ai
ARISTOTLE_CHAIN_ID=16661
GALILEO_CHAIN_ID=16602

# ---------- 0G Storage ----------
# Turbo and Standard indexers do NOT share files — pick one and stick with it.
ZG_STORAGE_INDEXER_URL=https://indexer-storage-testnet-turbo.0g.ai

# ---------- 0G Compute (Sealed Inference) ----------
# Set after running: 0g-compute-cli inference list-providers
ZG_COMPUTE_PROVIDER=0xREPLACE_ME
ZG_COMPUTE_API_KEY=REPLACE_ME

# ---------- Re-encryption (Sealed Inference commitment-binder, Hack A) ----------
# 32-byte hex master key for HKDF-derived per-agent keys. Held in the bridge
# process for the hackathon (production: rotate to a registered SP node once
# 0G's broker accepts non-LLM service types). Generate: `openssl rand -hex 32`.
RE_ENC_MASTER_KEY=REPLACE_ME

# Sealed Inference provider's signing address — captured from the first RA
# report and registered on-chain via TEEVerifier.registerOracle(addr, pubkey).
ORACLE_SIGNER_ADDRESS=0xREPLACE_ME

# ---------- Block explorer / verification ----------
BLOCKSCOUT_API_KEY=any-non-empty-string

# ---------- Contracts (filled in after deploy) ----------
NEXT_PUBLIC_AGENT_NFT_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_TEE_VERIFIER_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_ROYALTY_HOOK_ADDRESS=0x0000000000000000000000000000000000000000
PLATFORM_TREASURY=0xREPLACE_ME

# ---------- Frontend ----------
NEXT_PUBLIC_DEFAULT_CHAIN_ID=16602
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=REPLACE_ME

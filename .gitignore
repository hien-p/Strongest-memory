# Env / secrets — never commit these
.env
.env.local
.env.*
!.env.example
.dev.vars
.dev.vars.*
*.key
*.pem

# Node
node_modules/
.pnpm-store/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Build outputs
dist/
build/
out/
.next/
.turbo/
.cache/
*.tsbuildinfo
.vercel

# Vite emits the React landing into apps/landing/dist/ then CI copies into
# apps/web/ at deploy time. Built artifacts are not source — keep out of git.
apps/landing/dist/
apps/landing/.vite/
# apps/web/index.html and apps/web/assets/ are produced by `pnpm landing:stage`
# and rebuilt fresh on every CI deploy. Hashes change per build, so don't track.
apps/web/index.html
apps/web/assets/

# Wrangler / Cloudflare
.wrangler/
wrangler.toml.bak

# Foundry
packages/contracts/out/
packages/contracts/cache/
packages/contracts/broadcast/
!packages/contracts/broadcast/**/run-*.json

# Rust
apps/oracle/target/
apps/oracle/Cargo.lock

# Local reference clones (use git submodules or pnpm patches if needed)
packages/contracts/contracts-fork/

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
logs/

# Test outputs
coverage/
